<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants Crafter PDF admins read + write access to CrafterPdfTemplate__mdt records so they can configure branding without code. Assign alongside CrafterPdfUser.</description>
    <label>Crafter PDF Admin</label>
    <classAccesses>
        <apexClass>CrafterPdfDeliveryJob</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CrafterPdfEmailService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CrafterPdfInvocable</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CrafterPdfScheduler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CrafterPdfService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <customMetadataTypeAccesses>
        <name>CrafterPdfTemplate__mdt</name>
        <enabled>true</enabled>
    </customMetadataTypeAccesses>
    <!-- Full FLS on all CrafterPdfTemplate__mdt fields for admins -->
    <fieldPermissions>
        <field>CrafterPdfTemplate__mdt.Brand_Color__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>CrafterPdfTemplate__mdt.Cover_Page__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>CrafterPdfTemplate__mdt.Footer_Text__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>CrafterPdfTemplate__mdt.Header_Text__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>CrafterPdfTemplate__mdt.Logo_Static_Resource__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>CrafterPdfTemplate__mdt.Page_Size__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <objectPermissions>
        <object>ContentVersion</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <hasActivationRequired>false</hasActivationRequired>
</PermissionSet>
