<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__FlowScreen</target>
        <target>lightningCommunity__Page</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__RecordPage,lightning__HomePage">
            <property
                name="reportIds"
                type="String"
                label="Report IDs (comma-separated)"
                description="Up to 5 Salesforce report IDs to include in the briefing book." />
            <property
                name="templateDeveloperName"
                type="String"
                label="Template Developer Name"
                description="DeveloperName of the CrafterPdfTemplate__mdt record."
                default="Default" />
            <property
                name="bookTitle"
                type="String"
                label="Book Title"
                description="Cover page title and file name for the exported PDF."
                default="Briefing Book" />
            <property
                name="buttonLabel"
                type="String"
                label="Button Label"
                default="Export Briefing Book" />
            <property
                name="saveToFiles"
                type="Boolean"
                label="Save to Salesforce Files"
                default="false" />
            <property
                name="linkedRecordId"
                type="String"
                label="Linked Record ID"
                description="Optional. Links the saved ContentVersion to this SObject record." />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
